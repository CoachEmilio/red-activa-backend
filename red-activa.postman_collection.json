{
  "info": {
    "name": "Red Activa API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login - Dr. Carlos (Italiano)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json(); if (r.result && r.data?.token) pm.collectionVariables.set('token', r.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos.mendez@italiano.org.ar\",\n  \"password\": \"test\"\n}"
            }
          }
        },
        {
          "name": "Login - Enf. Laura (Italiano)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json(); if (r.result && r.data?.token) pm.collectionVariables.set('token', r.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"laura.garcia@italiano.org.ar\",\n  \"password\": \"test\"\n}"
            }
          }
        },
        {
          "name": "Login - Lic. Sofia (Aleman)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json(); if (r.result && r.data?.token) pm.collectionVariables.set('token', r.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sofia.rodriguez@aleman.org.ar\",\n  \"password\": \"test\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Institutions",
      "item": [
        {
          "name": "Get Nearest Institution",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/institutions/nearby?longitude=-58.4217&latitude=-34.6039&maxDistance=5000",
              "host": ["{{baseUrl}}"],
              "path": ["institutions", "nearby"],
              "query": [
                { "key": "longitude", "value": "-58.4217", "description": "Longitud del punto de referencia" },
                { "key": "latitude", "value": "-34.6039", "description": "Latitud del punto de referencia" },
                { "key": "maxDistance", "value": "5000", "description": "Distancia maxima en metros (default 10000)", "disabled": true }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Persons (NN)",
      "item": [
        {
          "name": "Get All Persons",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/persons",
              "host": ["{{baseUrl}}"],
              "path": ["persons"],
              "query": [
                { "key": "status", "value": "UNIDENTIFIED", "description": "UNIDENTIFIED | POTENTIAL_MATCH | IDENTIFIED", "disabled": true },
                { "key": "institution", "value": "<id>", "description": "Filtrar por institucion (ObjectId)", "disabled": true },
                { "key": "gender", "value": "MALE", "description": "MALE | FEMALE", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Person by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/persons/:id",
            "variable": [{ "key": "id", "value": "<person_id>" }]
          }
        },
        {
          "name": "Create Person",
          "description": "multipart/form-data. 'address', 'neighborhood', 'geoLocation', 'reportedBy', 'assignedTo', 'institution' y 'dateOfAdmission' se calculan automaticamente del token y la institucion del usuario. Al crear un NN se dispara un job en background que compara 'distinctiveFeatures' via IA (Gemini) contra los reportes de desaparecidos del mismo genero, barrio y rango de edad, y guarda los matches con score > 60 en SimilarityMatch. Imagenes opcionales (campo 'images', hasta 10, jpg/png/webp, max 5MB c/u) solo se pueden cargar en este paso, no hay endpoint para agregarlas despues.",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/persons",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "estimatedAgeMin", "value": "40", "type": "text", "description": "Edad minima estimada visualmente" },
                { "key": "estimatedAgeMax", "value": "50", "type": "text", "description": "Edad maxima estimada visualmente" },
                { "key": "gender", "value": "MALE", "type": "text", "description": "MALE | FEMALE" },
                { "key": "height", "value": "1.72", "type": "text", "description": "Opcional. Metros (0.3 - 2.5)" },
                { "key": "weight", "value": "78", "type": "text", "description": "Opcional. Kg" },
                {
                  "key": "distinctiveFeatures",
                  "value": "Tatuaje de cruz en antebrazo izquierdo. Cicatriz en ceja derecha. Usa anteojos de armazon negra.",
                  "type": "text",
                  "description": "Usado por el motor de similitud. Se compara textualmente via IA contra la descripcion de cada reporte candidato."
                },
                { "key": "consciousnessLevel", "value": "CONSCIOUS", "type": "text", "description": "CONSCIOUS | DISORIENTED | UNCONSCIOUS | SEDATED" },
                { "key": "images", "value": "", "type": "file", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Update Person",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/persons/:id",
            "variable": [{ "key": "id", "value": "<person_id>" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"POTENTIAL_MATCH\",\n  \"assignedTo\": \"EAAF\"\n}",
              "description": "status: UNIDENTIFIED | POTENTIAL_MATCH | IDENTIFIED. Campos actualizables: estimatedAgeMin, estimatedAgeMax, gender, height, weight, distinctiveFeatures, consciousnessLevel, status, assignedTo."
            }
          }
        },
        {
          "name": "Get Person Similarity Matches",
          "description": "Devuelve los reportes de desaparecidos que hicieron match con este NN, ordenados por score descendente. Score entre 1 y 100, devuelto por la IA. Incluye 'differences' (contradicciones detectadas) y 'reasoning' (justificacion). Solo se guardan matches con score > 60.",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/persons/:id/similarities",
            "variable": [{ "key": "id", "value": "<person_id>" }]
          }
        }
      ]
    },
    {
      "name": "Reports (Desaparecidos)",
      "item": [
        {
          "name": "Get All Reports",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/reports",
              "host": ["{{baseUrl}}"],
              "path": ["reports"]
            }
          }
        },
        {
          "name": "Get Report by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/reports/:id",
            "variable": [{ "key": "id", "value": "<report_id>" }]
          }
        },
        {
          "name": "Get Report Similarity Matches",
          "description": "Devuelve los NN que hicieron match con este reporte de desaparecido, ordenados por score descendente. Popula datos del NN: estimatedAgeMin, estimatedAgeMax, gender, distinctiveFeatures, status, address, dateOfAdmission, identifyingPhotos.",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/reports/:id/similarities",
            "variable": [{ "key": "id", "value": "<report_id>" }]
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "By Neighborhood",
          "description": "Agrupa casos de NN y reportes de desaparecidos por barrio. Permite identificar zonas con alta concentracion de casos no resueltos. Resultado: array de { neighborhood, persons, reports }.",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/analytics/by-neighborhood"
          }
        },
        {
          "name": "Heatmap",
          "description": "Retorna las instituciones con cantidad de NN activos, incluyendo coordenadas GeoJSON para renderizar un heatmap. Resultado: array de { institution, count, geoLocation: { type: Point, coordinates: [lon, lat] } }.",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/analytics/heatmap"
          }
        },
        {
          "name": "Summary",
          "description": "Resumen ejecutivo via $facet. Incluye: total de NN, distribucion por estado (UNIDENTIFIED/POTENTIAL_MATCH/IDENTIFIED), distribucion por genero, total de reportes de desaparecidos, distribucion de reportes por genero, top 5 barrios con mas reportes, y total de matches de similitud guardados.",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/analytics/summary"
          }
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload Image",
          "description": "Sube una imagen generica. Campo form-data: 'image'.",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/upload",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "image", "value": "", "type": "file" }
              ]
            }
          }
        }
      ]
    }
  ]
}
